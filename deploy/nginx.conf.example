# nginx — cvm.com.ve (WordPress en / + Registro Jurídico en /consultoria)
# Copiar a /etc/nginx/sites-available/cvm.com.ve y recargar:
#   nginx -t && systemctl reload nginx

# -----------------------------------------------------------
# HTTP -> HTTPS
# -----------------------------------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name cvm.com.ve;
    root /var/www/web;
    index index.php;

    location / {
        return 301 https://$host$request_uri;
    }

    location ~ /.well-known/acme-challenge {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr:$remote_port;
        proxy_pass http://127.0.0.1:9180;
    }
}

# -----------------------------------------------------------
# HTTPS
# -----------------------------------------------------------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name cvm.com.ve;
    root /var/www/web;
    index index.php;
    client_max_body_size 20M;

    ssl_certificate     /etc/nginx/ssl/cvm.com.ve_EC256/fullchain.cer;
    ssl_certificate_key /etc/nginx/ssl/cvm.com.ve_EC256/private.key;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers "EECDH+AESGCM:EDH+AESGCM:AES256+EECDH:AES256+EDH";
    ssl_prefer_server_ciphers on;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "upgrade-insecure-requests";

    access_log /var/log/nginx/wordpress-access.log;
    error_log  /var/log/nginx/wordpress-error.log warn;

    charset utf-8;

    # =========================================================
    # REGISTRO JURÍDICO (/consultoria)
    # =========================================================

    # --- Backend Express (Node :3022) — API ---
    # El prefijo /consultoria/api se reescribe a /api en Express.
    location /consultoria/api/ {
        proxy_pass http://127.0.0.1:3022/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        client_max_body_size 200M;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # --- Backend Express (Node :3022) — PDFs subidos ---
    location /consultoria/uploads/ {
        proxy_pass http://127.0.0.1:3022/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        expires 1d;
        add_header Cache-Control "public, no-transform";
    }

    # --- /consultoria -> /consultoria/ ---
    location = /consultoria {
        return 301 /consultoria/;
    }

    # --- Frontend React (SPA) ---
    # Archivos: /var/www/web/consultoria/  (contenido de client/dist)
    # IMPORTANTE: usar root (no alias) y declarar index index.html.
    location /consultoria/ {
        root /var/www/web;
        index index.html;
        try_files $uri $uri/ /consultoria/index.html;
    }

    # =========================================================
    # WORDPRESS (raíz)
    # =========================================================
    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        try_files $uri =404;
        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60s;
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
    }

    location ~* \.(js|css|png|mp4|mp3|mkv|jpg|jpeg|zip|gif|ico|svg|woff|woff2|ttf|otf)$ {
        expires max;
        log_not_found off;
        access_log off;
        add_header Cache-Control "public, no-transform";
    }

    location ~* /(?:uploads|files)/.*\.php$ {
        deny all;
    }
    location ~* ^/(wp-config.php|readme.html|license.txt|wp-admin/includes) {
        deny all;
    }
    location ~ /\.(?!well-known).* {
        deny all;
        access_log off;
        log_not_found off;
    }
    location ~ /.well-known/acme-challenge {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr:$remote_port;
        proxy_pass http://127.0.0.1:9180;
    }
}
